# Configuracion OpenAI
OPENAI_API_KEY=PON AQUI TU API KEY DE OPENAI
OPENAI_MODEL=gpt-4.1

#Configuracion entorno
APP_ENV=local
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log  # Si se deja en blanco solo stdout

# Base de datos para auditoria
AUDIT_ENABLED=true

# Base de datos Postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/phishing_detect
DB_ECHO=false

# APIS para reputacion
VIRUSTOTAL_API_KEY=PON AQUI TU API KEY DE VIRUSTOTAL (opcional)

# Redis (Celery broker + backend)
REDIS_URL=redis://localhost:6379/0

# Qdrant (vector store RAG CU-04)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=phishing_docs

# Google Gemini (LLM + embeddings RAG CU-04)
GOOGLE_API_KEY=PON AQUI TU API KEY DE GOOGLE GEMINI
CU04_SIMILARITY_TOP_K=5
CU04_CHUNK_SIZE=1200
CU04_CHUNK_OVERLAP=200
CU04_AUTO_INGEST=true